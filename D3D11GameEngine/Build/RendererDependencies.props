<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IncludePath>$(EngineRoot)ThirdParty\DirectXTex2022\include;$(IncludePath)</IncludePath>
    <LibraryPath>$(EngineRoot)ThirdParty\DirectXTex2022\DebugLib;$(LibraryPath)</LibraryPath>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <Link>
      <AdditionalDependencies>BaseLibrary.lib;d3d11.lib;dxgi.lib;d3dcompiler.lib;d2d1.lib;dwrite.lib;Shlwapi.lib;DirectXTex.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
</Project>
