<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="UserMacros">
    <EngineRoot>$(MSBuildThisFileDirectory)..\</EngineRoot>
    <EngineBinDir>$(EngineRoot)Bin\$(Platform)\$(Configuration)\</EngineBinDir>
  </PropertyGroup>

  <PropertyGroup>
    <OutDir>$(EngineBinDir)</OutDir>
    <IntDir>$(EngineBinDir)$(ProjectName)\</IntDir>
    <IncludePath>$(EngineRoot);$(IncludePath)</IncludePath>
    <LibraryPath>$(EngineBinDir);$(LibraryPath)</LibraryPath>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
      <LanguageStandard>stdcpp17</LanguageStandard>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
